{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "3 days",
  "rangeStrategy": "pin",
  "labels": ["dependencies"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "automerge": false,
  "packageRules": [
    {
      "matchManagers": ["poetry"],
      "enabled": true
    }
  ]
}
